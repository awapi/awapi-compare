{
  "name": "awapi-compare-root",
  "version": "0.0.0",
  "private": true,
  "description": "AwapiCompare — cross-platform Beyond Compare alternative by Awapi.",
  "author": "Awapi",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev": "pnpm --filter @awapi/desktop dev",
    "build": "pnpm -r run build",
    "clean": "pnpm -r exec rm -rf dist out build coverage .turbo .tsbuildinfo && rm -rf release"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.8.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
