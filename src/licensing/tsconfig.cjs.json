{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist/cjs",
    "rootDir": "./src",
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "incremental": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts", "dist", "node_modules"]
}
